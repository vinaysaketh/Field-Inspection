{
  "expo": {
    "name": "FieldSnap Pro",
    "slug": "fieldsnap-pro",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "fieldsnap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Capture photos for field observations",
        "NSPhotoLibraryUsageDescription": "Save annotated observation images",
        "NSPhotoLibraryAddUsageDescription": "Save annotated observation images",
        "NSLocationWhenInUseUsageDescription": "Stamp GPS location on captured images",
        "NSFaceIDUsageDescription": "Unlock the app using Face ID"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A2463"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A2463"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Capture photos for field observations"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Stamp GPS location on captured images"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Unlock FieldSnap Pro using Face ID"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
